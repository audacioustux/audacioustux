#!/usr/bin/env sh
set -eu

# ── Resolve the real script directory (follows symlinks) ──────────────────────
# When installed via symlink (e.g. ~/.local/bin/ask-cli → /path/to/ask-cli),
# we need the real directory so Deno can find src/main.ts and deno.lock.

SELF="$0"
while [ -L "$SELF" ]; do
  DIR=$(CDPATH= cd -- "$(dirname -- "$SELF")" && pwd)
  TARGET=$(readlink "$SELF")
  case "$TARGET" in
    /*) SELF="$TARGET" ;;
    *)  SELF="$DIR/$TARGET" ;;
  esac
done
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SELF")" && pwd)

# ── Run with frozen lockfile ──────────────────────────────────────────────────
# --no-config   ignore any root deno.json (works inside host Deno workspaces)
# --lock/--frozen  enforce exact dependency versions from deno.lock
# --allow-read     read subject files, repo contents (bounded)
# --allow-env      read model/config env vars plus HOME/USERPROFILE
#                   (HOME is needed to resolve ~/.gemini/antigravity-cli/settings.json
#                    for the agy model-mismatch warning)
# --allow-run      invoke git and child CLIs

exec deno run \
  --no-config \
  --lock="$SCRIPT_DIR/deno.lock" \
  --frozen \
  --quiet \
  --no-prompt \
  --allow-read \
  --allow-env=ASK_AI_MODEL_CLAUDE,ASK_AI_MODEL_AGY,ASK_AI_MODEL_PI,HOME,USERPROFILE \
  --allow-run=git,claude,agy,pi \
  "$SCRIPT_DIR/src/main.ts" "$@"
